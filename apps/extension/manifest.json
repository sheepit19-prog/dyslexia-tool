{
  "manifest_version": 3,
  "name": "Dyslexia Tool",
  "version": "1.1.0",
  "description": "Free dyslexia reading & writing tools — font changes, text-to-speech, reading ruler, and voice notes.",
  "icons": {
    "16": "icons/png/icon16-16.png",
    "48": "icons/png/icon48-48.png",
    "128": "icons/png/icon128-128.png"
  },
  "permissions": [
    "activeTab",
    "storage"
  ],
  "host_permissions": [
    "<all_urls>"
  ],
  "action": {
    "default_popup": "popup/index.html",
    "default_title": "Dyslexia Tool",
    "default_icon": {
      "16": "icons/png/icon16-16.png",
      "48": "icons/png/icon48-48.png",
      "128": "icons/png/icon128-128.png"
    }
  },
  "background": {
    "service_worker": "src/background/index.ts",
    "type": "module"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["src/content/index.tsx"],
      "css": ["src/content/styles.css"],
      "run_at": "document_idle",
      "all_frames": false
    }
  ],
  "options_page": "options/index.html",
  "content_security_policy": {
    "extension_pages": "script-src 'self' 'wasm-unsafe-eval'; worker-src 'self' blob:; object-src 'self'"
  },
  "web_accessible_resources": [
    {
      "resources": ["fonts/*", "icons/*", "workers/*"],
      "matches": ["<all_urls>"]
    }
  ],
  "commands": {
    "toggle-font": {
      "description": "Toggle dyslexia font",
      "suggested_key": { "default": "Ctrl+Shift+F" }
    },
    "read-aloud": {
      "description": "Read selected text aloud",
      "suggested_key": { "default": "Ctrl+Shift+R" }
    },
    "toggle-bionic-reading": {
      "description": "Toggle bionic reading mode",
      "suggested_key": { "default": "Ctrl+Shift+B" }
    },
    "toggle-reading-ruler": {
      "description": "Toggle reading ruler",
      "suggested_key": { "default": "Ctrl+Shift+L" }
    }
  },
  "minimum_chrome_version": "90"
}
